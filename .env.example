# =============================================================================
# SentinelWatch — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# Database (RDS PostgreSQL)
# ---------------------------------------------------------------------------
# Full connection string, e.g.:
#   postgresql://user:password@host:5432/sentinelwatch
# For local development you can run Postgres via Docker:
#   docker run -p 5432:5432 -e POSTGRES_PASSWORD=secret postgres
DATABASE_URL=postgresql://postgres:secret@localhost:5432/sentinelwatch

# Set to "false" to disable TLS (useful for local Postgres without SSL).
# In production leave this as "true" (default).
DB_SSL=true

# ---------------------------------------------------------------------------
# RPC URLs (archive / full nodes recommended for balance queries)
# Leave blank to disable that chain — the adapter will error at runtime.
# ---------------------------------------------------------------------------
ETHEREUM_RPC_URL=
BINANCE_RPC_URL=
AVALANCHE_RPC_URL=
ARBITRUM_RPC_URL=
BASE_RPC_URL=
OPTIMISM_RPC_URL=
POLYGON_RPC_URL=
SONIC_RPC_URL=
GNOSIS_RPC_URL=
LINEA_RPC_URL=
CELO_RPC_URL=
UNICHAIN_RPC_URL=

# ---------------------------------------------------------------------------
# AWS (only needed for local serverless-offline or CLI deploys)
# ---------------------------------------------------------------------------
AWS_REGION=eu-central-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
