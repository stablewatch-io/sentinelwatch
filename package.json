{
  "name": "sentinelwatch",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "migrate": "node-pg-migrate up --migration-file-language sql --migrations-dir migrations",
    "deploy:env": "sls deploy --stage $NODE_ENV",
    "deploy:dev": "export NODE_ENV=dev && npm run deploy:env",
    "deploy:prod": "export NODE_OPTIONS=--max-old-space-size=6144 && export NODE_ENV=prod && npm run deploy:env",
    "deploy": "npm run deploy:dev",
    "serve": "node --max-old-space-size=8192 node_modules/serverless/bin/serverless offline start",
    "test:watch": "jest --watch",
    "build": "sls package"
  },
  "overrides": {
    "ansi-regex": "5.0.1",
    "mocha": {
      "nanoid": "3.3.1"
    }
  },
  "dependencies": {
    "@babel/core": "^7.13.10",
    "@babel/preset-env": "^7.13.12",
    "@babel/preset-typescript": "^7.13.0",
    "@supercharge/promise-pool": "^3.2.0",
    "@types/aws-lambda": "^8.10.72",
    "@types/node": "^22.5.4",
    "@types/pg": "^8.11.6",
    "async-retry": "^1.3.1",
    "aws-sdk": "^2.869.0",
    "axios": "^1.7.7",
    "babel-core": "^6.26.3",
    "babel-jest": "^29.7.0",
    "babel-loader": "^9.1.3",
    "dotenv": "^16.4.5",
    "esbuild": "^0.14.27",
    "ethers": "^6.13.2",
    "jest": "^29.7.0",
    "node-pg-migrate": "^7.7.0",
    "pg": "^8.12.0",
    "serverless": "^2.31.0",
    "serverless-esbuild": "^1.26.1",
    "serverless-prune-plugin": "^2.0.2",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2"
  },
  "packageManager": "pnpm@9.5.0+sha512.140036830124618d624a2187b50d04289d5a087f326c9edfc0ccd733d76c4f52c3a313d4fc148794a2a9d81553016004e6742e8cf850670268a7387fc220c903"
}
